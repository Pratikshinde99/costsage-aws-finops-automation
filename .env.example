# Core AWS + Storage
AWS_REGION=us-east-1
REPORT_BUCKET=your-costsage-report-bucket
REPORT_PREFIX=daily
DDB_TABLE=CostTrends

# Notifications
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:CostSageAlerts
SLACK_WEBHOOK_SECRET_NAME=costsage/slack-webhook

# Required governance tags
REQUIRED_TAGS=Owner,Project,Environment

# Alerting thresholds
ANOMALY_MULTIPLIER=1.30
MISSING_TAGS_ALERT_THRESHOLD=5
POTENTIAL_SAVINGS_ALERT_THRESHOLD=100.0
MONTHLY_BUDGET_USD=0.0
BUDGET_ALERT_THRESHOLD_PCT=80.0

# Feature toggles
INCLUDE_ELB_CHECK=true

# Pricing assumptions (used by savings_calculator.py)
EC2_DEFAULT_HOURLY_USD=0.05
EBS_GP3_GB_MONTH_USD=0.08
SNAPSHOT_GB_MONTH_USD=0.05

# Optional per-instance-type hourly overrides
# Example: m5.large:0.096,t3.micro:0.0104
EC2_TYPE_HOURLY_OVERRIDES=
